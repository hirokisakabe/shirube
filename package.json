{
	"name": "shirube",
	"version": "0.3.2",
	"description": "仕事のtodo",
	"repository": {
		"type": "git",
		"url": "https://github.com/hirokisakabe/shirube"
	},
	"bin": {
		"shirube": "dist/cli.js"
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "rm -rf dist && vite build --outDir dist/web && esbuild src/cli/index.ts --bundle --platform=node --format=cjs --outfile=dist/cli.js --external:better-sqlite3 && esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/server.js --external:better-sqlite3 && cp -r drizzle dist/drizzle && chmod +x dist/cli.js",
		"dev:server": "tsx watch src/server/index.ts",
		"dev:web": "vite",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
		"generate": "drizzle-kit generate",
		"migrate": "drizzle-kit migrate",
		"test": "vitest run --config vitest.node.config.ts && vitest run --config vitest.web.config.ts && vitest run --config vitest.cli.config.ts",
		"lint": "eslint .",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"knip": "knip",
		"release": "pnpm build && changeset publish"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.8.0",
		"@tanstack/react-query": "^5.101.0",
		"better-sqlite3": "^11.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^9.39.4",
		"@hono/node-server": "^1.14.0",
		"@tanstack/react-router": "^1.121.12",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/better-sqlite3": "^7.6.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.1.5",
		"@vitejs/plugin-react": "^4.5.2",
		"commander": "^15.0.0",
		"drizzle-kit": "^0.31.0",
		"drizzle-orm": "^0.45.2",
		"esbuild": "^0.25.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"globals": "^17.6.0",
		"hono": "^4.7.0",
		"jsdom": "^26.1.0",
		"knip": "^6.15.0",
		"msw": "^2.14.6",
		"prettier": "^3.8.4",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsx": "^4.8.1",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.61.0",
		"vite": "^6.3.5",
		"vitest": "^4.1.8"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	}
}
